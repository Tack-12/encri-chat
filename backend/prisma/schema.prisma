// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
id Int @id 
username String @unique
firstname String
lastname String
password String

chats Chat[]
sentMessages Messages[] @relation("SentBy")
receivedMessages Messages[] @relation("SentTo")

}

//A third table to manage one - many relation between chats
model Chat {

chatid Int @id @default(autoincrement())

user User @relation(fields: [userId], references:[id])
userId Int

message Messages[]

}

model Messages {
message String
msg_id Int @id

chats Chat @relation(fields: [chatId], references: [chatid])
chatId Int

sentBy User @relation("SentBy", fields: [sentById ], references:[id]) 
sentById Int


sentTo User @relation("SentTo", fields: [sentToId], references:[id]) 
sentToId Int

createdAt  DateTime  @default(now()) 
}
